#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

# Check if mise is installed
if ! command -v mise >/dev/null 2>&1; then
    echo "mise not found, installing..."
    curl https://mise.run/bash | sh

    # Add to PATH for current session
    export PATH="$HOME/.local/bin:$PATH"

    if ! command -v mise >/dev/null 2>&1; then
        echo "Error: mise installation failed"
        exit 1
    fi
fi

# Install tools (Python, uv, ruff)
mise install -q

# Bootstrap venv + deps if not already done
if [ ! -d "$SCRIPT_DIR/.venv" ]; then
    mise exec -- uv venv "$SCRIPT_DIR/.venv"
fi
VIRTUAL_ENV="$SCRIPT_DIR/.venv" mise exec -- uv pip install -q -r "$SCRIPT_DIR/requirements.txt"

exec "$SCRIPT_DIR/.venv/bin/python" "$SCRIPT_DIR/dev" "$@"
