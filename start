#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
cd "$SCRIPT_DIR"

# Ensure mise's default install location is on PATH before checking
export PATH="$HOME/.local/bin:$PATH"

# Check if mise is installed
if ! command -v mise >/dev/null 2>&1; then
    echo "mise not found, installing..."
    curl https://mise.run/bash | sh

    if ! command -v mise >/dev/null 2>&1; then
        echo "Error: mise installation failed"
        exit 1
    fi
fi

# Trust the config and install tools (Python, uv, ruff)
mise trust -q
mise install -q

# mise exec auto-creates the venv (_.python.venv in mise.toml), then install deps
mise exec -- uv pip install -q -r "$SCRIPT_DIR/requirements.txt"

exec "$SCRIPT_DIR/.venv/bin/python" "$SCRIPT_DIR/dev" "$@"
